;src.split(/\r?\n/).forEach((raw,k)=>{let t=raw.trim(),l=k+1;if(!t||t[0]==='#')return;let sp=(raw.match(/^\s*/)||[''])[0];if(sp.includes('\t')||sp.length%4)throw new X('Indent blocks with four spaces.',l);let i=sp.length;while(stack.length>1&&i<=stack.at(-1).i)stack.pop();let p=stack.at(-1);if(i!==p.i+4)throw new X('This line is indented farther than the block above it.',l);let m;if(m=t.match(/^Make a recipe called (.+):$/i)){let n={type:'recipe',name:m[1],b:[],l};p.b.push(n);recipes.set(m[1].toLowerCase(),n);stack.push({i,b:n.b});last.delete(i)}else if(m=t.match(/^If (.+):$/i)){let n={type:'if',bs:[{q:m[1],b:[],l}],o:[],l};p.b.push(n);last.set(i,n);stack.push({i,b:n.bs[0].b})}else if(m=t.match(/^Otherwise(?:,)? if (.+):$/i)){let n=last.get(i);if(!n)throw new X('Put Otherwise if directly after an If block.',l);let z={q:m[1],b:[],l};n.bs.push(z);stack.push({i,b:z.b})}else if(/^Otherwise:$/i.test(t)){let n=last.get(i);if(!n)throw new X('Put Otherwise directly after an If block.',l);stack.push({i,b:n.o})}else if(m=t.match(/^For every ([a-z][\w-]*)(?: in ([a-z][\w-]*))?:$/i)){let n={type:'for',item:m[1],col:(m[2]||`${m[1]}s`).toLowerCase(),b:[],l};p.b.push(n);stack.push({i,b:n.b});last.delete(i)}else{if(!t.endsWith('.'))throw new X(`This instruction needs a period.\n\nI read: ${t}`,l);p.b.push({type:'s',t:t.slice(0,-1),l});last.delete(i)}});return{b:root,recipes}}
function count(d,n){if(!d)return 0;if(/row/i.test(n))return d.kind==='table'?d.rows.length:0;if(/base/i.test(n))return stats(d).total;return stats(d).count}function cmp(a,o,b){o=o.toLowerCase();return/(below|under|less|fewer)/.test(o)?a<b:/(above|over|more|greater)/.test(o)?a>b:/at least/.test(o)?a>=b:/(at most|no more)/.test(o)?a<=b:a===b}
function cond(q,c,l){let a=q.split(/\s+or\s+/i);if(a.length>1)return a.some(x=>cond(x,c,l));a=q.split(/\s+and\s+/i);if(a.length>1)return a.every(x=>cond(x,c,l));if(/^not /i.test(q))return!cond(q.replace(/^not /i,''),c,l);let m;if(m=q.match(/^(fewer than|less than|more than|over|at least|at most) (\d+) (reads|sequences|rows|contigs|bases)(?: remain)?$/i))return cmp(count(c.data,m[3]),m[1],+m[2]);if(m=q.match(/^(?:the )?(read|sequence|row|contig|base) count (is below|is above|is at least|is at most|equals) (\d+)$/i))return cmp(count(c.data,m[1]),m[2],+m[3]);if(m=q.match(/^the average quality (is below|is above|is at least|is at most) ([\d.]+)$/i))return cmp(stats(c.data).q,m[1],+m[2]);if(m=q.match(/^the GC content (is below|is above|is at least|is at most) ([\d.]+) percent$/i))return cmp(stats(c.data).gc,m[1],+m[2]);if(m=q.match(/^the assembly has (fewer than|more than|at least|at most) (\d+) contigs$/i))return cmp(count(c.data,'contigs'),m[1],+m[2]);if(m=q.match(/^the file (.+) exists$/i))return!!find(c.files,repl(m[1],c));if(/^the result is empty$/i.test(q))return count(c.data,c.data?.kind==='table'?'rows':'sequences')===0;if(/^the result is not empty$/i.test(q))return count(c.data,c.data?.kind==='table'?'rows':'sequences')>0;if(/^resistance genes were found$/i.test(q))return(c.flags.resistance||0)>0;if(/^no resistance genes were found$/i.test(q))return(c.flags.resistance||0)===0;if(/^virulence genes were found$/i.test(q))return(c.flags.virulence||0)>0;if(/^plasmids were found$/i.test(q))return(c.flags.plasmids||0)>0;if(m=q.match(/^the sample name contains (.+)$/i))return!!c.sample?.name.toLowerCase().includes(m[1].toLowerCase());throw new X(`I do not understand this decision yet.\n\nI read: ${q}`,l)}
function decision(q,v,path,l){sec('Decision',{p:[`Line ${l}: ${q}`,`The condition was ${v?'true':'false'}.`,`The program followed the ${path} path.`]})}
function prep(c,l){if(!c.data||!['seq','pair'].includes(c.data.kind))throw new X('Open FASTQ reads first.',l);let before=stats(c.data);for(let r of rec(c.data)){let ps=AD.map(x=>r.sequence.indexOf(x)).filter(x=>x>=0);if(ps.length){let n=Math.min(...ps);r.sequence=r.sequence.slice(0,n);r.quality=r.quality?.slice(0,n)??null}}if(c.data.kind==='pair'){let keep=[];for(let i=0;i<c.data.a.records.length;i++){let x=c.data.a.records[i],y=c.data.b.records[i];if(aq(x)>=20&&aq(y)>=20&&x.sequence.length>=50&&y.sequence.length>=50)keep.push([x,y])}c.data.a.records=keep.map(x=>x[0]);c.data.b.records=keep.map(x=>x[1])}else c.data.records=c.data.records.filter(x=>aq(x)>=20&&x.sequence.length>=50);let after=stats(c.data);sec('Bacterial reads prepared',{p:['Browser method: adapter trimming, Q20 filtering, and a 50-base minimum.',`Reads before\n${before.count}`,`Reads remaining\n${after.count}`]})}
function overlap(a,b,min=18){for(let n=Math.min(a.length,b.length,180);n>=min;n--)if(a.slice(-n)===b.slice(0,n))return n;return 0}function assemble(c,names,folder,l){let rs=names.flatMap(n=>rec(open(c,repl(n,c),l)));if(rs.length>8000||rs.reduce((a,x)=>a+x.sequence.length,0)>4000000)throw new X('This browser assembly is limited to 8,000 reads or 4,000,000 bases. Translate the same program for SPAdes when the dataset is larger.',l);let a=[...new Set(rs.map(x=>x.sequence))].sort((x,y)=>y.length-x.length).slice(0,900);for(let pass=0;pass<6;pass++){let best=[-1,-1,0,''];for(let i=0;i<a.length;i++)for(let j=0;j<a.length;j++)if(i!==j){let o=overlap(a[i],a[j]);if(o>best[2])best=[i,j,o,a[i]+a[j].slice(o)]}if(best[2]<18)break;a=a.filter((_,i)=>i!==best[0]&&i!==best[1]);a.push(best[3]);a.sort((x,y)=>y.length-x.length)}let out=`${folder.replace(/[\\/]$/,'')}/contigs.fasta`;c.data={kind:'seq',format:'fasta',records:a.map((s,i)=>({name:`contig-${i+1}`,sequence:s,quality:null})),sourceName:out};c.f